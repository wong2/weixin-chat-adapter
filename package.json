{
  "name": "chat-adapter-weixin",
  "version": "0.1.3",
  "description": "Weixin iLink bot adapter for Chat SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "weixin-chat-adapter": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "prepare": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "chat": "^4.31.0"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.31.0",
    "qrcode-terminal": "^0.12.0"
  },
  "optionalDependencies": {
    "silk-wasm": "^3.7.1"
  },
  "devDependencies": {
    "@chat-adapter/state-memory": "^4.31.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "chat": "^4.31.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat-sdk",
    "chat-adapter",
    "weixin",
    "wechat",
    "bot"
  ],
  "license": "MIT"
}
